{
  "name": "trusteed/agentic-commerce-prestashop",
  "description": "Trusteed Agentic MCP Stores PrestaShop module — AgenticTools integration",
  "type": "prestashop-module",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "Trusteed\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Trusteed\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
