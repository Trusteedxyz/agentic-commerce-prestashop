<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
  <file source-language="en-US" target-language="de-DE" datatype="plaintext"
        original="agenticmcpstores">
    <body>
      <trans-unit id="AgenticMcpStores_back">
        <source>Back</source>
        <target>Zurück</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_before_you_begin_please_confirm">
        <source>Before you begin, please confirm:</source>
        <target>Bevor Sie beginnen, bestätigen Sie bitte:</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_bootstrap_secret">
        <source>Bootstrap Secret</source>
        <target>Bootstrap-Geheimnis</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_bootstrap_secret_is_required">
        <source>Bootstrap Secret is required.</source>
        <target>Das Bootstrap-Geheimnis ist erforderlich.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_bootstrap_secret_is_too_short_minimum_32">
        <source>Bootstrap Secret is too short (minimum 32 characters).</source>
        <target>Das Bootstrap-Geheimnis ist zu kurz (mindestens 32 Zeichen).</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_bootstrap_secret_must_be_at_least_32_ch">
        <source>Bootstrap Secret must be at least 32 characters.</source>
        <target>Das Bootstrap-Geheimnis muss mindestens 32 Zeichen haben.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_check_credentials">
        <source>Check credentials</source>
        <target>Anmeldedaten prüfen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_click_the_button_below_to_verify_that_yo">
        <source>Click the button below to verify that your store can communicate with the Trusteed API.</source>
        <target>Klicken Sie auf die Schaltfläche unten, um zu überprüfen, ob Ihr Shop mit der Trusteed-API kommunizieren kann.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_connect">
        <source>Connect</source>
        <target>Verbinden</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_connected_as_merchant">
        <source>Connected as merchant</source>
        <target>Als Händler verbunden</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_connecting">
        <source>Connecting…</source>
        <target>Verbindung wird hergestellt…</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_connection_failed">
        <source>Connection failed.</source>
        <target>Verbindung fehlgeschlagen.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_connection_successful">
        <source>Connection successful!</source>
        <target>Verbindung erfolgreich!</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_connect_to_the_trusteed_portal">
        <source>Connect to the Trusteed Portal</source>
        <target>Mit dem Trusteed-Portal verbinden</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_copy_your_merchant_id_and_bootstrap_secre">
        <source>Copy your Merchant ID and Bootstrap Secret — you will paste them in the next step.</source>
        <target>Kopieren Sie Ihre Händler-ID und Ihr Bootstrap-Geheimnis — Sie fügen diese im nächsten Schritt ein.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_credentials">
        <source>Credentials</source>
        <target>Anmeldedaten</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_credentials_not_saved_yet_please_go_bac">
        <source>Credentials not saved yet. Please go back to step 3.</source>
        <target>Anmeldedaten noch nicht gespeichert. Bitte gehen Sie zurück zu Schritt 3.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_enter_your_credentials">
        <source>Enter Your Credentials</source>
        <target>Geben Sie Ihre Anmeldedaten ein</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_error">
        <source>Error:</source>
        <target>Fehler:</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_get_started">
        <source>Get started</source>
        <target>Loslegen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_i_have_my_credentials">
        <source>I have my credentials</source>
        <target>Ich habe meine Anmeldedaten</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_keep_this_value_confidential_it_is_stored">
        <source>Keep this value confidential. It is stored encrypted in your PrestaShop database.</source>
        <target>Halten Sie diesen Wert vertraulich. Er wird verschlüsselt in Ihrer PrestaShop-Datenbank gespeichert.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_log_in_with_your_trusteed_account">
        <source>Log in with your Trusteed account.</source>
        <target>Melden Sie sich mit Ihrem Trusteed-Konto an.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_merchant_id">
        <source>Merchant ID</source>
        <target>Händler-ID</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_merchant_id_is_required">
        <source>Merchant ID is required.</source>
        <target>Die Händler-ID ist erforderlich.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_navigate_to_connect_a_store_and_select_p">
        <source>Navigate to "Connect a Store" and select PrestaShop.</source>
        <target>Gehen Sie zu „Shop verbinden" und wählen Sie PrestaShop.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_network_error">
        <source>Network error.</source>
        <target>Netzwerkfehler.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_note_you_are_on_a_sub_shop_some_settings">
        <source>Note: you are on a sub-shop. Some settings are shared with the main shop.</source>
        <target>Hinweis: Sie befinden sich in einem Unter-Shop. Einige Einstellungen werden mit dem Hauptshop geteilt.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_open_portal">
        <source>Open Portal</source>
        <target>Portal öffnen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_open_the_trusteed_portal_in_a_new_tab">
        <source>Open the Trusteed portal in a new tab:</source>
        <target>Öffnen Sie das Trusteed-Portal in einem neuen Tab:</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_open_trust_center">
        <source>Open Trust Center</source>
        <target>Vertrauenszentrum öffnen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_paste_your_64_character_hex_secret_here">
        <source>Paste your 64-character hex secret here</source>
        <target>Fügen Sie hier Ihr 64-stelliges Hex-Geheimnis ein</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_please_enter_your_bootstrap_secret">
        <source>Please enter your Bootstrap Secret.</source>
        <target>Bitte geben Sie Ihr Bootstrap-Geheimnis ein.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_please_enter_your_merchant_id">
        <source>Please enter your Merchant ID.</source>
        <target>Bitte geben Sie Ihre Händler-ID ein.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_request_failed_please_try_again">
        <source>Request failed. Please try again.</source>
        <target>Anfrage fehlgeschlagen. Bitte versuchen Sie es erneut.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_save_and_continue">
        <source>Save and continue</source>
        <target>Speichern und fortfahren</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_saving">
        <source>Saving…</source>
        <target>Wird gespeichert…</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_security_token_mismatch_please_refresh_th">
        <source>Security token mismatch. Please refresh the page.</source>
        <target>Sicherheitstoken stimmt nicht überein. Bitte aktualisieren Sie die Seite.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_test">
        <source>Test</source>
        <target>Testen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_test_connection">
        <source>Test connection</source>
        <target>Verbindung testen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_test_your_connection">
        <source>Test Your Connection</source>
        <target>Ihre Verbindung testen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_the_trusteed_api_rejected_the_connection">
        <source>The Trusteed API rejected the connection. Check your credentials.</source>
        <target>Die Trusteed-API hat die Verbindung abgelehnt. Überprüfen Sie Ihre Anmeldedaten.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_this_wizard_will_connect_your_prestashop_s">
        <source>This wizard will connect your PrestaShop store to the Trusteed Trust Center in 4 quick steps.</source>
        <target>Dieser Assistent verbindet Ihren PrestaShop-Shop in 4 schnellen Schritten mit dem Trusteed-Vertrauenszentrum.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_trusteed_is_already_configured">
        <source>Trusteed is already configured.</source>
        <target>Trusteed ist bereits konfiguriert.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_uuid_provided_by_the_trusteed_portal">
        <source>UUID provided by the Trusteed portal.</source>
        <target>UUID vom Trusteed-Portal bereitgestellt.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_welcome">
        <source>Welcome</source>
        <target>Willkommen</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_welcome_to_trusteed">
        <source>Welcome to Trusteed</source>
        <target>Willkommen bei Trusteed</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_you_can_re_run_this_wizard_to_update_your">
        <source>You can re-run this wizard to update your credentials.</source>
        <target>Sie können diesen Assistenten erneut ausführen, um Ihre Anmeldedaten zu aktualisieren.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_you_have_access_to_back_office_module_conf">
        <source>You have access to Back Office module configuration.</source>
        <target>Sie haben Zugang zur Modulkonfiguration im Back Office.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_you_have_a_trusteed_account_at_app_trusted">
        <source>You have a Trusteed account at app.trusteed.xyz</source>
        <target>Sie haben ein Trusteed-Konto unter app.trusteed.xyz</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_you_have_super_admin_privileges_on_this_p">
        <source>You have Super Admin privileges on this PrestaShop installation.</source>
        <target>Sie haben Super-Admin-Rechte auf dieser PrestaShop-Installation.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_your_store_has_outbound_https_access_to_ap">
        <source>Your store has outbound HTTPS access to api.trusteed.xyz</source>
        <target>Ihr Shop hat ausgehenden HTTPS-Zugriff auf api.trusteed.xyz</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_quick_setup">
        <source>Quick Setup</source>
        <target>Schnelleinrichtung</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_trusteed_connection">
        <source>Trusteed connection</source>
        <target>Trusteed-Verbindung</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_api_base_url">
        <source>API Base URL</source>
        <target>API-Basis-URL</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_uuid_provided_by_trusteed_onboarding">
        <source>UUID provided by Trusteed onboarding</source>
        <target>UUID aus dem Trusteed-Onboarding</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_hex_secret_from_portal_onboarding">
        <source>Hex secret from portal onboarding</source>
        <target>Hex-Geheimnis aus dem Portal-Onboarding</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_default_https_api_trusteed_xyz">
        <source>Default: https://api.trusteed.xyz</source>
        <target>Standard: https://api.trusteed.xyz</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_save">
        <source>Save</source>
        <target>Speichern</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_settings_updated">
        <source>Settings updated</source>
        <target>Einstellungen aktualisiert</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_embed_the_trusteed_trust_center_inside_pre">
        <source>Embed the Trusteed Trust Center inside PrestaShop Back Office.</source>
        <target>Binden Sie das Trusteed-Vertrauenszentrum in das PrestaShop Back Office ein.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_trusteed_trust_center">
        <source>Trusteed Trust Center</source>
        <target>Trusteed Vertrauenszentrum</target>
      </trans-unit>
    </body>
  </file>
