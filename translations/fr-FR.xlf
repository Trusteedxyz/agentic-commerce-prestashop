        <target>Copiez votre ID Marchand et votre Secret d'Amorçage — vous les collerez à l'étape suivante.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_credentials">
        <source>Credentials</source>
        <target>Identifiants</target>
      </trans-unit>
