        <target>Cet assistant connectera votre boutique PrestaShop au Centre de Confiance Trusteed en 4 étapes rapides.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_trusteed_is_already_configured">
        <source>Trusteed is already configured.</source>
        <target>Trusteed est déjà configuré.</target>
      </trans-unit>
      <trans-unit id="AgenticMcpStores_uuid_provided_by_the_trusteed_portal">
